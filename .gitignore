# --- Obsidian プラグイン公開用 .gitignore ---

# 依存
node_modules/

# pnpm 専用プロジェクト: npm / yarn のロックファイルは混在禁止（jest ツリー汚染の原因になる）
package-lock.json
yarn.lock

# ビルド成果物（main.js は GitHub Release に添付するため Git では管理しない）
main.js
*.js.map
dist/
build/

# テスト
coverage/

# 環境変数・ログ
.env
.env.*
*.log

# secretlint のローカル専用デニーリスト（社名・個人ホスト名など。公開リポに残さない）
.secretlintrc.local.json

# OS / エディタ
.DS_Store
Thumbs.db
.vscode/
.idea/

# --- 開発専用ファイル（プラグイン公開リポジトリには含めない） ---
refs/
.specify/
.claude/
specs/
report/
CLAUDE.md

# TypeScript incremental build info
*.tsbuildinfo
.env

# Playwright MCP snapshot output
.playwright-mcp/
/report/
