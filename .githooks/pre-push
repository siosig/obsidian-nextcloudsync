#!/bin/sh
# Release-hygiene gate for the Nextcloud Sync Obsidian plugin.
#
# Runs before every `git push` (wired up via core.hooksPath, set by the package.json
# "prepare" script on `pnpm install`). It blocks a push when:
#   1. the Obsidian community-store linter reports errors (eslint-plugin-obsidianmd) —
#      this is exactly what delisted the plugin from the store before;
#   2. the type-check + production build fails;
#   3. either README is out of sync with manifest.json — README.md AND README.ja.md must
#      each name the current version in their "What's new" heading and mention the current
#      minAppVersion, so a release can't ship with stale docs or an out-of-sync translation.
#
# Bypass in an emergency with: git push --no-verify
set -e

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

echo "pre-push: Obsidian community-store lint…"
pnpm lint

echo "pre-push: type-check + production build…"
pnpm build

VERSION="$(node -p "require('./manifest.json').version")"
MIN_APP="$(node -p "require('./manifest.json').minAppVersion")"

# The version appears in the "What's new" heading with ASCII parens in README.md and
# full-width parens in README.ja.md, so accept either form.
check_readme() {
  file="$1"
  if ! { grep -qF "($VERSION)" "$file" || grep -qF "（$VERSION）" "$file"; }; then
    echo "pre-push: $file has no \"What's new\" heading for version $VERSION." >&2
    echo "          Update its release notes to match manifest.json version $VERSION (or push with --no-verify)." >&2
    exit 1
  fi
  if ! grep -qF "$MIN_APP" "$file"; then
    echo "pre-push: $file does not mention minAppVersion $MIN_APP from manifest.json." >&2
    echo "          Update its Requirements section (or push with --no-verify)." >&2
    exit 1
  fi
}

check_readme README.md
check_readme README.ja.md

echo "pre-push: lint, build, and README/README.ja sync checks passed."
