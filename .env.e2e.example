# E2E test configuration (example) — copy to a gitignored env file (e.g. .env) and fill in.
# The live E2E suite (pnpm test:e2e) reads these. If any is missing/empty, the suite skips.
# NEVER commit real values. Use a Nextcloud APP PASSWORD, not your login password.

# WebDAV files endpoint of the target server (.../remote.php/dav/files/<user>[/...])
NEXTCLOUD_SERVER_URL="https://example.invalid/remote.php/dav/files/USER"

# Vault name = top remote folder the tests operate under (OPTIONAL — if empty/unset,
# tests operate directly under the SERVER_URL root, emulating the "no vault yet" state).
# Each run isolates into [NEXTCLOUD_VAULT_NAME/]e2e-<timestamp>-<rand>/ and deletes it after.
NEXTCLOUD_VAULT_NAME="ObsidianVault"

# Account username
NEXTCLOUD_USER="USER"

# Nextcloud app password (used as the WebDAV app password)
NEXTCLOUD_PASSWORD="XXXXX-XXXXX-XXXXX-XXXXX-XXXXX"
